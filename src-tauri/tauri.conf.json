{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dispatch",
  "version": "0.2.3",
  "identifier": "com.lucasaguiar.dispatch",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dispatch",
        "width": 1400,
        "height": 900,
        "minWidth": 720,
        "minHeight": 480,
        "maximized": true,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 29 },
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3OENBNUYxQjY2QTE5OTQKUldTVUdXcTI4YVdNZC9MdmppQlNEUFlHdmJMMWwxOEp6bWZFc0k3a0R4cnM2NFRoVlFXUy9NTXkK",
      "endpoints": [
        "https://github.com/laguiarx/dispatch/releases/latest/download/latest.json"
      ]
    }
  }
}
